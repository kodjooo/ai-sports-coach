# ---- Telegram ----
# Токен бота. Где взять: Telegram → @BotFather → /newbot (или /token для существующего)
TG_TOKEN=

# ---- OpenAI ----
# Ключ API. Где взять: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Модель для рассуждений (диалог, фидбек, Vision)
OPENAI_MODEL=gpt-5
# Модель эмбеддингов для векторной памяти
OPENAI_EMBED_MODEL=text-embedding-3-small
# Модель распознавания речи (голосовые сообщения): whisper-1 или gpt-4o-transcribe
OPENAI_TRANSCRIBE_MODEL=whisper-1
# Режим рассуждений для gpt-5: minimal|low|medium|high (low — быстро и дёшево)
OPENAI_REASONING_EFFORT=low
# Режим рассуждений для онбординга (генерация персонального промпта)
OPENAI_REASONING_EFFORT_ONBOARDING=medium

# ---- PostgreSQL ----
# Логин/пароль/имя БД. Используются и контейнером postgres, и ботом.
POSTGRES_USER=coach
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=coach
# Хост/порт задаются в docker-compose.yml (postgres:5432). Локально можно переопределить.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- ChromaDB ----
# Хост/порт векторной БД. В compose это сервис chroma:8000.
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ---- Планировщик ----
# Часовой пояс для утренних напоминаний и недельных отчётов.
TZ=Europe/Chisinau
# Время утреннего напоминания (часы:минуты, 24ч)
REMINDER_HOUR=8
REMINDER_MINUTE=0
